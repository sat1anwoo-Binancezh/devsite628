{
  "name": "mail-notifier-beta",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "node server/index.js",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "pack": "npm run build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "imapflow": "^1.0.194",
    "mailparser": "^3.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "playwright": "^1.60.0"
  },
  "build": {
    "appId": "com.ikunance.mailnotifier.beta",
    "productName": "IKUNANCE Mail Notifier Beta",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron-main.js",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
